# Supabase (Dashboard → Project Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Storage bucket for payment screenshots
SUPABASE_STORAGE_BUCKET=payment-screenshots

# App URL — set to your Vercel URL in production (e.g. https://your-app.vercel.app)
APP_URL=http://localhost:3000
PORT=3000

# --- Gmail (App Password) ---
# 1. Google Account → Security → 2-Step Verification (must be ON)
# 2. Security → App passwords → create one for "Mail"
# 3. Use that 16-character password below (no spaces)
# FROM_EMAIL must be the same Gmail address as SMTP_USER

FROM_EMAIL=yourname@gmail.com
FROM_NAME=Trans Bharat Aviation

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=yourname@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# Leave Resend unset when using Gmail
# RESEND_API_KEY=
